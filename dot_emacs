;; --- Package Management ---
(require 'package)
(add-to-list 'package-archives '("melpa" . "https://melpa.org/packages/") t)
(package-initialize)

;; --- General Settings ---
(setq inhibit-splash-screen t)
(setq auto-save-list-file-name "~/.emacs-save")
(setq-default fill-column 76)
(setq delete-by-moving-to-trash t
      trash-directory "~/.Trash/emacs")
(setq ns-pop-up-frames nil)

;; Display time in mode line
(display-time-mode t)

;; Highlight matching parentheses
(show-paren-mode t)

;; Replace selected text when typing
(delete-selection-mode 1)

;; Disable toolbar and scroll bar
(when (fboundp 'tool-bar-mode)
  (tool-bar-mode -1))
(when (fboundp 'scroll-bar-mode)
  (scroll-bar-mode -1))

;; Line numbers in programming modes
(add-hook 'prog-mode-hook #'display-line-numbers-mode)

;; --- Indentation ---
(setq-default indent-tabs-mode nil)
(setq-default sgml-basic-offset 4)
(setq-default nxml-child-indent 2)
(setq js-indent-level 4)
(setq py-indent-offset 4)

;; --- Scrolling ---
(setq mouse-wheel-progressive-speed nil)
(setq mouse-wheel-follow-mouse t)
(setq scroll-step 1)

;; --- macOS Key Bindings ---
;; Swap Command and Option keys
(setq mac-option-modifier 'super)
(setq mac-command-modifier 'meta)
(setq ns-function-modifier 'hyper)

;; Disable C-z minimize
(put 'suspend-frame 'disabled t)

;; --- Global Key Bindings ---
(global-set-key "\M-g" 'goto-line)
(global-set-key (kbd "M-<f10>") 'toggle-frame-fullscreen)

;; --- Font ---
(when (display-graphic-p)
  (set-face-attribute 'default nil
                      :family "Source Code Pro"
                      :height 130))

;; --- Auto-install packages ---
(defvar my-packages '(monokai-theme markdown-mode))
(unless (cl-every #'package-installed-p my-packages)
  (package-refresh-contents)
  (dolist (pkg my-packages)
    (unless (package-installed-p pkg)
      (package-install pkg))))

;; --- Theme ---
(load-theme 'monokai t)

;; --- Markdown ---
(autoload 'markdown-mode "markdown-mode" "Major mode for Markdown" t)
(add-to-list 'auto-mode-alist '("\\.md\\'" . markdown-mode))
(add-to-list 'auto-mode-alist '("\\.markdown\\'" . markdown-mode))
(add-to-list 'auto-mode-alist '("README\\.md\\'" . gfm-mode))

;; --- Spell Check ---
(setq ispell-program-name "aspell")
